PORT=5000
JWT_SECRET=change_me_in_production
ADMIN_EMAIL=admin@bitsathy.ac.in
ADMIN_PASSWORD=change_me
ADMIN_NAME=Placement Admin
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
MONGODB_DB=placement_app

# OTP settings (optional)
OTP_VERIFY_TTL_MS=60000
OTP_VERIFIED_TTL_MS=900000
OTP_RESEND_COOLDOWN_MS=30000
OTP_MAX_ATTEMPTS=5
OTP_DEBUG=true

# Email OTP via SMTP (optional; if not set, OTP is mocked/logged)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SMS OTP via Twilio (optional; if not set, OTP is mocked/logged)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
